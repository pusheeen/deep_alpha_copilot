# SEC API Configuration
# Replace with your name and email for SEC API requests
SEC_USER_AGENT=Your Name your.email@example.com

# Neo4j Database Configuration (optional - disabled by default)
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_password_here
# NEO4J_DATABASE=neo4j

# Reddit API Configuration
# Get credentials from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FinancialAgent/1.0 by u/YourUsername

# X/Twitter API Configuration
# Option 1: Use Bearer Token (Recommended - simpler)
# Get this from https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=your_x_bearer_token_here

# Option 2: Use OAuth 1.0a credentials (if you don't have Bearer Token)
# You need ALL of these if not using Bearer Token
# X_API_KEY=your_api_key_here
# X_API_SECRET=your_api_secret_here
# X_ACCESS_TOKEN=your_access_token_here
# X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Note: X API Basic tier costs $100/month
# Free tier is very limited and may not work for this application

# Gemini API Configuration
# Used for news interpretation and AI analysis
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Custom Search API Configuration
# Used for fetching latest news for specific tickers
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
# Create a custom search engine at https://programmablesearchengine.google.com/
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# YouTube API Configuration
# Get from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Cloud Project Configuration
GCP_PROJECT_ID=your-gcp-project-id

# Email Notification Settings
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# Financial Modeling Prep API
# Get from https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# FRED API (Federal Reserve Economic Data)
# Get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Session Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=generate_a_random_secret_key_here

# CORS Configuration (for production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Stripe Configuration (optional - for payment features)
# Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PRICE_ID=your_stripe_price_id
# DOMAIN=https://your-domain.com

# Data Directory (optional - auto-detected based on environment)
# Leave commented for automatic detection
# DATA_ROOT=./data
