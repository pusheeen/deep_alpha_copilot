{
  "site_name": "Closed Loop",
  "base_url": "https://frontend-blond-zeta-20.vercel.app",
  "spec": "A web app with user log in. This page is about all the news that I could potentially be interested in (source: google news, emails I receive from various subscriptions, whatever page I have bookmarked in chrome). I want a tl;dr summary of the news and make sure the news aren't click bait (so you need to generate a meaningful title based on the news content). Make sure it loads fast (cache etc). I want the news to be fresh (past 72 hours).",
  "flows": [
    {
      "name": "registration",
      "steps": [
        { "action": "fetch_page", "url": "/register", "expect": "registration form" },
        {
          "action": "api_call",
          "method": "POST",
          "url": "/api/auth/register",
          "body": { "email": "simuser_{timestamp}@test.com", "username": "simuser_{timestamp}", "password": "SimPass123" },
          "save_token": true,
          "expect": "access_token in response"
        }
      ]
    },
    {
      "name": "login",
      "steps": [
        { "action": "fetch_page", "url": "/login", "expect": "login form" },
        {
          "action": "api_call",
          "method": "POST",
          "url": "/api/auth/login",
          "body": { "email": "{registered_email}", "password": "SimPass123" },
          "save_token": true,
          "expect": "access_token in response"
        }
      ]
    },
    {
      "name": "view_profile",
      "steps": [
        {
          "action": "api_call",
          "method": "GET",
          "url": "/api/auth/me",
          "auth": true,
          "expect": "user info returned"
        }
      ]
    },
    {
      "name": "browse_feed",
      "steps": [
        { "action": "fetch_page", "url": "/feed", "expect": "news feed with articles" },
        {
          "action": "api_call",
          "method": "GET",
          "url": "/api/news/feed?topics=technology&limit=10&summarize=false",
          "auth": true,
          "expect": "articles array with news items"
        },
        {
          "action": "api_call",
          "method": "GET",
          "url": "/api/news/feed?topics=AI,finance&limit=5&summarize=false",
          "auth": true,
          "expect": "multi-topic articles"
        }
      ]
    },
    {
      "name": "manage_sources",
      "steps": [
        { "action": "fetch_page", "url": "/sources", "expect": "source management page" },
        {
          "action": "api_call",
          "method": "POST",
          "url": "/api/sources/add",
          "body": { "source_type": "rss", "name": "Hacker News", "config": { "url": "https://news.ycombinator.com/rss" } },
          "auth": true,
          "expect": "source created"
        },
        {
          "action": "api_call",
          "method": "GET",
          "url": "/api/sources/list",
          "auth": true,
          "expect": "sources list with added source"
        }
      ]
    },
    {
      "name": "performance",
      "steps": [
        { "action": "timing", "url": "/", "expect": "< 2000ms" },
        { "action": "timing", "url": "/login", "expect": "< 2000ms" },
        { "action": "timing", "url": "/feed", "expect": "< 2000ms" },
        { "action": "timing", "url": "/api/health", "expect": "< 500ms" },
        {
          "action": "timing",
          "url": "/api/news/feed?topics=technology&limit=5&summarize=false",
          "auth": true,
          "expect": "< 5000ms"
        }
      ]
    }
  ],
  "browser_flows": [
    {
      "name": "register_via_ui",
      "steps": [
        { "action": "goto", "url": "/register", "description": "Navigate to registration page" },
        { "action": "assert_visible", "selector": "form", "description": "Registration form is visible" },
        { "action": "fill", "selector": "#reg-email", "value": "browsertest_{timestamp}@test.com", "description": "Fill email field" },
        { "action": "fill", "selector": "#reg-username", "value": "browsertest_{timestamp}", "description": "Fill username field" },
        { "action": "fill", "selector": "#reg-password", "value": "BrowserTest123", "description": "Fill password field" },
        { "action": "click", "selector": "button[type='submit']", "description": "Click submit button" },
        { "action": "wait", "timeout": 3000, "description": "Wait for registration to complete" }
      ]
    },
    {
      "name": "login_via_ui",
      "steps": [
        { "action": "goto", "url": "/login", "description": "Navigate to login page" },
        { "action": "assert_visible", "selector": "form", "description": "Login form is visible" },
        { "action": "fill", "selector": "#login-email", "value": "browsertest_{timestamp}@test.com", "description": "Fill email field" },
        { "action": "fill", "selector": "#login-password", "value": "BrowserTest123", "description": "Fill password field" },
        { "action": "click", "selector": "button[type='submit']", "description": "Click login button" },
        { "action": "wait", "timeout": 3000, "description": "Wait for login to complete" }
      ]
    },
    {
      "name": "browse_feed_ui",
      "steps": [
        { "action": "goto", "url": "/feed", "description": "Navigate to feed page" },
        { "action": "wait", "timeout": 8000, "description": "Wait for articles to load" },
        { "action": "assert_visible", "selector": "article, [class*='article'], [class*='card'], [class*='skeleton']", "description": "Article cards or loading skeletons are visible", "timeout": 10000 }
      ]
    },
    {
      "name": "manage_sources_ui",
      "steps": [
        { "action": "goto", "url": "/sources", "description": "Navigate to sources page" },
        { "action": "wait", "timeout": 3000, "description": "Wait for page to render" },
        { "action": "assert_visible", "selector": "button, form, [class*='source']", "description": "Source management UI is visible" }
      ]
    }
  ],
  "pages_to_audit": ["/", "/login", "/register", "/feed", "/sources"],
  "evaluation_criteria": [
    "usability",
    "visual_design",
    "performance",
    "spec_compliance",
    "error_handling",
    "mobile_responsiveness",
    "accessibility",
    "content_quality",
    "feature_completeness"
  ]
}
