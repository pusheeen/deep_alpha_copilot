{
  "name": "user-agent-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "Generalized user simulator that visits a website, tests flows, and generates product feedback",
  "scripts": {
    "simulate": "npx tsx src/simulate.ts",
    "simulate:closed-loop": "npx tsx src/simulate.ts --config configs/closed-loop.json",
    "simulate:http-only": "npx tsx src/simulate.ts --config configs/closed-loop.json --no-browser",
    "simulate:browser-only": "npx tsx src/simulate.ts --config configs/closed-loop.json --browser-only"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
